      "*helm uninstall*": "ask",
      "*helm delete*": "ask",

      "*rm -rf /*": "deny",
      "*rm -rf ~*": "deny",
      "*rm -rf .": "deny",
      "*rm -rf ..": "deny",
      "*rm -rf .*": "deny",
      "*rm -rf *": "ask",
      "*rmdir *": "ask",
      "*sudo rm*": "deny",
      "*sudo rmdir*": "deny",
      "*sudo *": "ask",
      "*su *": "ask",
      "*chmod 777 *": "deny",
