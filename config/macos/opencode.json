          "limit": { "context": 256000, "output": 128000 }
        },
        "gpt-5.1-codex-mini": {
          "limit": { "context": 256000, "output": 128000 }
        },
        "gpt-5.2": {
          "limit": { "context": 400000, "output": 128000 }
