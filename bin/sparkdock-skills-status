#!/usr/bin/env bash

set -euo pipefail

# sparkdock-skills-status — Show status of agent skills (managed vs user-owned).

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"

# Source shared utility library (provides logging + compute_sha256)
# shellcheck source=common/utils.sh
source "${SCRIPT_DIR}/common/utils.sh"

SKILLS_DIR="${HOME}/.agents/skills"
MANIFEST_PATH="${HOME}/.cache/sparkdock/sf-skills-manifest.json"
CACHE_DIR="${HOME}/.cache/sparkdock/agent-skills"
SYSTEM_SKILLS_SUBDIR="skills/system"

# Guard: python3 is required for manifest operations
if ! command -v python3 &>/dev/null; then
    log_error "python3 is required but not found in PATH"
    exit 1
fi

log_section "Agent Skills Status"

if [[ ! -d "${SKILLS_DIR}" ]]; then
    log_warn "No skills directory found at ${SKILLS_DIR}"
    exit 0
fi

# Fetch the upstream skills cache so status reflects the true upstream state.
# Uses fetch + reset --hard (mirrors sparkdock-skills-sync) to handle divergence
# from upstream force-pushes. Avoids 2>/dev/null on run_with_spinner because
# redirecting stderr breaks gum spin (it draws the spinner on stderr).
CACHE_AVAILABLE=false
if [[ -d "${CACHE_DIR}/.git" ]]; then
    if run_with_spinner "Fetching upstream skills..." \
            git -C "${CACHE_DIR}" fetch origin -q; then
        git -C "${CACHE_DIR}" reset --hard origin/main -q 2>/dev/null
        CACHE_AVAILABLE=true
    else
        log_warn "Could not reach upstream — status may not reflect latest changes."
        CACHE_AVAILABLE=true  # Still use whatever is cached locally
    fi
fi

# Get managed skill names from manifest
managed_skills=""
if [[ -f "${MANIFEST_PATH}" ]]; then
    managed_skills=$(python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    for name in sorted(data.get('skills', {}).keys()):
        print(name)
except Exception:
    pass
" "${MANIFEST_PATH}" 2>/dev/null || true)
fi

printf "%-25s %-12s %s\n" "SKILL" "TYPE" "STATUS"
printf "%-25s %-12s %s\n" "-----" "----" "------"

for skill_dir in "${SKILLS_DIR}"/*/; do
    [[ -d "${skill_dir}" ]] || continue
    skill_name=$(basename "${skill_dir}")

    if [[ ! -f "${skill_dir}/SKILL.md" ]]; then
        printf "%-25s %-12s %s\n" "${skill_name}" "incomplete" "no SKILL.md"
        continue
    fi

    if echo "${managed_skills}" | grep -Fqx "${skill_name}"; then
        if [[ -f "${MANIFEST_PATH}" ]]; then
            manifest_sha=$(python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print(data.get('skills', {}).get(sys.argv[2], {}).get('sha256', ''))
except Exception:
    print('')
" "${MANIFEST_PATH}" "${skill_name}" 2>/dev/null || true)

            installed_sha=$(compute_sha256 "${skill_dir}/SKILL.md") || installed_sha=""

            if [[ "${manifest_sha}" == "${installed_sha}" ]]; then
                # Not locally modified — check upstream cache for a newer version.
                upstream_file="${CACHE_DIR}/${SYSTEM_SKILLS_SUBDIR}/${skill_name}/SKILL.md"
                if [[ "${CACHE_AVAILABLE}" == "true" ]] && [[ -f "${upstream_file}" ]]; then
                    upstream_sha=$(compute_sha256 "${upstream_file}") || upstream_sha=""
                    if [[ -n "${upstream_sha}" ]] && [[ "${upstream_sha}" != "${installed_sha}" ]]; then
                        printf "%-25s %-12s %s\n" "${skill_name}" "managed" "update available"
                    else
                        printf "%-25s %-12s %s\n" "${skill_name}" "managed" "up to date"
                    fi
                else
                    printf "%-25s %-12s %s\n" "${skill_name}" "managed" "up to date"
                fi
            else
                printf "%-25s %-12s %s\n" "${skill_name}" "managed" "locally modified"
            fi
        fi
    else
        printf "%-25s %-12s %s\n" "${skill_name}" "user" ""
    fi
done

echo ""
if [[ -f "${MANIFEST_PATH}" ]]; then
    log_info "Manifest: ${MANIFEST_PATH}"
else
    log_warn "No manifest found. Run 'sjust sf-skills-refresh' to sync."
fi
if [[ "${CACHE_AVAILABLE}" == "false" ]]; then
    log_warn "No upstream cache found. Run 'sjust sf-skills-refresh' to enable update checks."
fi
