#!/usr/bin/env bash

set -euo pipefail

# sparkdock-agents-status — Show status of agent skills and agent profiles
#                           (managed vs user-owned, up to date vs locally modified).

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"

# Source shared utility library (provides logging + compute_sha256)
# shellcheck source=common/utils.sh
source "${SCRIPT_DIR}/common/utils.sh"

SKILLS_DIR="${HOME}/.agents/skills"
COPILOT_SKILLS_DIR="${HOME}/.copilot/skills"
MANIFEST_PATH="${HOME}/.cache/sparkdock/sf-skills-manifest.json"
CACHE_DIR="${HOME}/.cache/sparkdock/agent-skills"
SYSTEM_SKILLS_SUBDIR="skills/system"
SYSTEM_AGENTS_SUBDIR="agents/system"

# Tool registry (must mirror sparkdock-agents-sync)
declare -A AGENT_TOOL_INSTALL_DIR=(
    [copilot]="${HOME}/.copilot/agents"
    [opencode]="${HOME}/.config/opencode/agents"
)

# Guard: python3 and perl are required
if ! command -v python3 &>/dev/null; then
    log_error "python3 is required but not found in PATH"
    exit 1
fi
if ! command -v perl &>/dev/null; then
    log_error "perl is required but not found in PATH"
    exit 1
fi

# --- Helpers ---

# Get list of managed resource names from a manifest section.
get_managed_names() {
    local section="$1"
    if [[ ! -f "${MANIFEST_PATH}" ]]; then
        return
    fi
    python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    for name in sorted(data.get(sys.argv[2], {}).keys()):
        print(name)
except Exception:
    pass
" "${MANIFEST_PATH}" "${section}" 2>/dev/null || true
}

# Get SHA from manifest for a given section and key.
get_manifest_sha() {
    local section="$1"
    local key="$2"
    if [[ ! -f "${MANIFEST_PATH}" ]]; then
        echo ""
        return
    fi
    python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print(data.get(sys.argv[2], {}).get(sys.argv[3], {}).get('sha256', ''))
except Exception:
    print('')
" "${MANIFEST_PATH}" "${section}" "${key}" 2>/dev/null || echo ""
}

# Check if an upstream resource exists at the given path.
# Returns 0 (conflict) or 1 (no conflict). Sets CONFLICTS_FOUND=true on hit.
has_upstream_conflict() {
    local upstream_path="$1"
    if [[ "${CACHE_AVAILABLE}" == "true" ]] && [[ -e "${upstream_path}" ]]; then
        CONFLICTS_FOUND=true
        return 0
    fi
    return 1
}

# Determine the status of a managed resource by comparing SHAs.
# Prints one of: "up to date", "update available", "locally modified".
# Args: <manifest_section> <manifest_key> <installed_file> <upstream_file>
#   upstream_file may be empty if unavailable.
resolve_managed_status() {
    local section="$1" key="$2" installed_file="$3" upstream_file="$4"
    local manifest_sha installed_sha upstream_sha

    manifest_sha=$(get_manifest_sha "${section}" "${key}")
    installed_sha=$(compute_sha256 "${installed_file}") || installed_sha=""

    if [[ "${manifest_sha}" != "${installed_sha}" ]]; then
        echo "locally modified"
        return
    fi

    # SHA matches manifest — check if upstream has a newer version
    if [[ -n "${upstream_file}" ]] && [[ -f "${upstream_file}" ]]; then
        upstream_sha=$(compute_sha256 "${upstream_file}") || upstream_sha=""
        if [[ -n "${upstream_sha}" ]] && [[ "${upstream_sha}" != "${installed_sha}" ]]; then
            echo "update available"
            return
        fi
    fi

    echo "up to date"
}

# Print a bold colored section label.
print_label() {
    local title="$1"
    if [[ "${HAS_GUM}" = true ]]; then
        gum style --bold --foreground 99 "${title}"
    else
        printf "${BOLD}%s${NC}\n" "${title}"
    fi
}

# Print dimmed text (adapts to terminal color scheme).
print_faint() {
    local text="$1"
    if [[ "${HAS_GUM}" = true ]]; then
        gum style --faint "${text}"
    else
        printf "\033[2m%s\033[0m\n" "${text}"
    fi
}

# Render a CSV table using gum table (with fallback to column).
# Workaround: gum v0.17.0 has a bug (charmbracelet/gum#833) where --print mode
# applies bold styling to the first data row (selected-row state leaks).
# We strip bold escape sequences (\e[1m) via perl to neutralise this.
# --header.foreground is also broken (colors first data row, not header), so we
# only use --border.foreground for styling.
# Status values are colorized post-render so they don't break column alignment.
render_table() {
    local csv_data="$1"
    if [[ "${HAS_GUM}" = true ]]; then
        echo "${csv_data}" | gum table --print \
            --border.foreground 240 \
            | perl -pe '
                s/\e\[1m//g;
                s/update available/\e[38;5;40mupdate available\e[0m/g;
                s/locally modified/\e[38;5;220mlocally modified\e[0m/g;
                s/conflicts with upstream/\e[38;5;220mconflicts with upstream\e[0m/g;
                s/no SKILL\.md/\e[38;5;220mno SKILL.md\e[0m/g;
            '
    else
        echo "${csv_data}" | column -t -s ','
    fi
}

# --- Upstream cache ---

log_section "Agent Resources Status"

CACHE_AVAILABLE=false
CONFLICTS_FOUND=false
if [[ -d "${CACHE_DIR}/.git" ]]; then
    if [[ "${SPARKDOCK_SKIP_FETCH:-}" == "true" ]]; then
        CACHE_AVAILABLE=true
    elif run_with_spinner "Fetching upstream..." \
            git -C "${CACHE_DIR}" fetch origin -q; then
        git -C "${CACHE_DIR}" reset --hard origin/main -q 2>/dev/null
        CACHE_AVAILABLE=true
    else
        log_warn "Could not reach upstream — status may not reflect latest changes."
        CACHE_AVAILABLE=true  # Still use whatever is cached locally
    fi
fi

# --- Skills section ---

managed_skills="$(get_managed_names "skills")"
skills_csv="NAME,TYPE,STATUS"
skills_found=false

if [[ -d "${SKILLS_DIR}" ]]; then
    for skill_dir in "${SKILLS_DIR}"/*/; do
        [[ -d "${skill_dir}" ]] || continue
        skills_found=true
        skill_name=$(basename "${skill_dir}")

        if [[ ! -f "${skill_dir}/SKILL.md" ]]; then
            skills_csv+=$'\n'"${skill_name},incomplete,no SKILL.md"
            continue
        fi

        if echo "${managed_skills}" | grep -Fqx "${skill_name}"; then
            upstream_file="${CACHE_DIR}/${SYSTEM_SKILLS_SUBDIR}/${skill_name}/SKILL.md"
            [[ "${CACHE_AVAILABLE}" != "true" || ! -f "${upstream_file}" ]] && upstream_file=""
            status=$(resolve_managed_status "skills" "${skill_name}" "${skill_dir}/SKILL.md" "${upstream_file}")
            skills_csv+=$'\n'"${skill_name},managed,${status}"
        else
            if has_upstream_conflict "${CACHE_DIR}/${SYSTEM_SKILLS_SUBDIR}/${skill_name}/SKILL.md"; then
                skills_csv+=$'\n'"${skill_name},user,conflicts with upstream"
            else
                skills_csv+=$'\n'"${skill_name},user,"
            fi
        fi
    done
fi

print_label "Skills"
if [[ "${skills_found}" = true ]]; then
    render_table "${skills_csv}"
else
    echo "  (no skills installed)"
fi

# --- Agents section ---

echo ""
managed_agents="$(get_managed_names "agents")"
agents_csv="NAME,TOOL,TYPE,STATUS"
agents_found=false

for tool_name in $(printf '%s\n' "${!AGENT_TOOL_INSTALL_DIR[@]}" | sort); do
    local_install_dir="${AGENT_TOOL_INSTALL_DIR[${tool_name}]}"
    [[ -d "${local_install_dir}" ]] || continue

    for agent_file in "${local_install_dir}"/*.md; do
        [[ -f "${agent_file}" ]] || continue
        agents_found=true

        filename="$(basename "${agent_file}")"
        agent_name="${filename%.agent.md}"
        if [[ "${agent_name}" == "${filename}" ]]; then
            agent_name="${filename%.md}"
        fi

        manifest_key="${agent_name}/${tool_name}"

        if echo "${managed_agents}" | grep -Fqx "${manifest_key}"; then
            # Resolve upstream file (agents use a directory with *.md glob)
            upstream_file=""
            upstream_dir="${CACHE_DIR}/${SYSTEM_AGENTS_SUBDIR}/${agent_name}/${tool_name}"
            if [[ "${CACHE_AVAILABLE}" == "true" ]] && [[ -d "${upstream_dir}" ]]; then
                for f in "${upstream_dir}"/*.md; do
                    [[ -f "${f}" ]] && upstream_file="${f}" && break
                done
            fi
            status=$(resolve_managed_status "agents" "${manifest_key}" "${agent_file}" "${upstream_file}")
            agents_csv+=$'\n'"${agent_name},${tool_name},managed,${status}"
        else
            if has_upstream_conflict "${CACHE_DIR}/${SYSTEM_AGENTS_SUBDIR}/${agent_name}/${tool_name}"; then
                agents_csv+=$'\n'"${agent_name},${tool_name},user,conflicts with upstream"
            else
                agents_csv+=$'\n'"${agent_name},${tool_name},user,"
            fi
        fi
    done
done

print_label "Agent Profiles"
if [[ "${agents_found}" = true ]]; then
    render_table "${agents_csv}"
else
    echo "  (no agent profiles installed)"
fi

# --- Copilot CLI skill symlinks ---
# Only warn when symlinks are missing or skipped — silent when everything is fine.
# Track: https://github.com/github/copilot-cli/issues/1744

copilot_issues=()
for skill_dir in "${SKILLS_DIR}"/*/; do
    [[ -d "${skill_dir}" ]] || continue
    local_skill_name=$(basename "${skill_dir}")
    copilot_target="${COPILOT_SKILLS_DIR}/${local_skill_name}"

    if [[ -L "${copilot_target}" ]]; then
        link_dest="$(readlink "${copilot_target}")"
        if [[ "${link_dest}" != "${SKILLS_DIR}/${local_skill_name}" ]]; then
            copilot_issues+=("${local_skill_name}: symlink points to ${link_dest} instead of ${SKILLS_DIR}/${local_skill_name}")
        fi
    elif [[ -e "${copilot_target}" ]]; then
        copilot_issues+=("${local_skill_name}: skipped (user content exists at ${copilot_target})")
    elif [[ -d "${SKILLS_DIR}" ]]; then
        copilot_issues+=("${local_skill_name}: not linked — run 'sjust sf-agents-refresh' to fix")
    fi
done

if [[ ${#copilot_issues[@]} -gt 0 ]]; then
    echo ""
    log_warn "Copilot CLI skill symlinks:"
    for issue in "${copilot_issues[@]}"; do
        log_warn "  ${issue}"
    done
fi

# --- Footer ---

echo ""
if [[ -f "${MANIFEST_PATH}" ]]; then
    print_faint "Manifest: ${MANIFEST_PATH}"
else
    log_warn "No manifest found. Run 'sjust sf-agents-refresh' to sync."
fi
if [[ "${CACHE_AVAILABLE}" == "false" ]]; then
    log_warn "No upstream cache found. Run 'sjust sf-agents-refresh' to enable update checks."
fi
if [[ "${CONFLICTS_FOUND}" == "true" ]]; then
    log_warn "Some user resources conflict with upstream. Run 'sjust sf-agents-refresh force' to overwrite."
fi
